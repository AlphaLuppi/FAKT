# ============================================================================
# FAKT API server — exemple d'environnement
# ============================================================================
#
# Copier vers `.env.local` (gitignored) et remplir.
# Mode 1 (solo local) : laisser AUTH_MODE=local + FAKT_API_TOKEN défini.
# Mode 2 (self-host)  : AUTH_MODE=jwt + DATABASE_URL Postgres + FAKT_JWT_SECRET.
# ============================================================================

# Mode d'authentification : "local" ou "jwt"
AUTH_MODE=local

# DB : chemin SQLite (mode 1) ou URL Postgres (mode 2)
# DATABASE_URL=postgres://fakt:fakt@localhost:5432/fakt
FAKT_DB_PATH=fakt.db

# Token shared mode 1 (>= 16 chars). Généré par Rust au spawn du sidecar.
FAKT_API_TOKEN=changeme_min_16_chars_random

# JWT secret mode 2 (>= 32 chars cryptographiquement aléatoire)
# Générer : openssl rand -base64 48
# FAKT_JWT_SECRET=

# Bind / port
BIND=127.0.0.1
FAKT_API_PORT=0

# CORS extra origins (CSV) — pour mode 2 fakt.alphaluppi.fr
# FAKT_API_EXTRA_ORIGINS=https://fakt.alphaluppi.fr,https://www.fakt.alphaluppi.fr

# Admin token one-shot pour migration data (>=32 chars). À ENLEVER après migration.
# FAKT_ADMIN_TOKEN=

# Storage PDFs signés (mode 2)
FAKT_SIGNED_PDFS_DIR=/var/lib/fakt/signed

# Logging
LOG_LEVEL=info
