{
  "name": "fakt",
  "private": true,
  "packageManager": "bun@1.3.2",
  "workspaces": ["apps/*", "packages/*", "packages/email", "landing"],
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "turbo run test",
    "test:e2e": "playwright test",
    "db:generate": "bun --cwd packages/db drizzle-kit generate",
    "db:migrate": "bun --cwd packages/db drizzle-kit migrate",
    "release": "turbo run build && bun --cwd apps/desktop tauri build"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9",
    "turbo": "^2.3",
    "typescript": "^5.6",
    "@playwright/test": "^1.49"
  },
  "dependencies": {
    "astro": "^6.1.9",
    "drizzle-orm": "^0.45.2",
    "esbuild": "^0.28.0",
    "vite": "^8.0.10"
  }
}
