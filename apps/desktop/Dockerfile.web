# syntax=docker/dockerfile:1.7

# ============================================================================
# FAKT web-frontend — Dockerfile.web
# ============================================================================
#
# Build : depuis la RACINE du repo (pas depuis apps/desktop/) :
#   docker build -f apps/desktop/Dockerfile.web -t fakt-web .
#
# Stage 1 : compile le bundle Vite avec FAKT_TARGET=web (output dist-web/).
# Stage 2 : Caddy alpine static qui sert dist-web/.
#
# Le reverse proxy Caddy externe (deploy/Caddyfile.alphaluppi) route /api/*
# vers api-server et tout le reste vers ce container sur le port 80.
#
# Cible : ~50 MB (Caddy alpine + bundle gzippé < 1 MB).
# ============================================================================

# ---- Stage 1 : Builder ----
FROM oven/bun:1.3.2-alpine AS builder

RUN apk add --no-cache python3 make g++

WORKDIR /app

# Copy workspace manifests pour caching install
COPY package.json bun.lock turbo.json tsconfig.base.json ./
COPY packages ./packages
COPY apps/desktop/package.json apps/desktop/tsconfig.json apps/desktop/vite.config.ts apps/desktop/index.html ./apps/desktop/
COPY landing/package.json ./landing/

RUN bun install --frozen-lockfile

# Copy le code source
COPY apps/desktop/src ./apps/desktop/src

# Build mode web — output dist-web/
WORKDIR /app/apps/desktop
RUN bun run build:web

# ---- Stage 2 : Runtime Caddy ----
FROM caddy:2-alpine AS runtime

COPY --from=builder /app/apps/desktop/dist-web /usr/share/caddy
COPY apps/desktop/Caddyfile.web /etc/caddy/Caddyfile

EXPOSE 80

# Healthcheck : Caddy doit servir index.html
HEALTHCHECK --interval=30s --timeout=5s --start-period=5s --retries=3 \
  CMD wget -qO- http://localhost/ > /dev/null || exit 1
