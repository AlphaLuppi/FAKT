{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities par défaut FAKT : fs scopé (drafts + AppData + Downloads), dialog save/open, shell open pour email/ZIP/URL externes.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:webview:default",
    "core:event:default",
    "core:path:default",
    "core:app:default",
    "shell:default",
    "shell:allow-open",
    "fs:default",
    "fs:allow-write-text-file",
    "fs:allow-read-text-file",
    "fs:allow-mkdir",
    "fs:allow-exists",
    "fs:allow-remove",
    {
      "identifier": "fs:scope",
      "allow": [
        {
          "path": "$TEMP/fakt-drafts/**"
        },
        {
          "path": "$APPDATA/fakt/**"
        },
        {
          "path": "$APPLOCALDATA/fakt/**"
        },
        {
          "path": "$DOWNLOAD/**"
        }
      ]
    },
    "dialog:default",
    "dialog:allow-save",
    "dialog:allow-open",
    "dialog:allow-message",
    "dialog:allow-confirm"
  ]
}
