{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "paths": {
      "@fakt/shared": ["../../packages/shared/src/index.ts"],
      "@fakt/design-tokens": ["../../packages/design-tokens/src/index.ts"],
      "@fakt/core": ["../../packages/core/src/index.ts"],
      "@fakt/legal": ["../../packages/legal/src/index.ts"],
      "@fakt/config": ["../../packages/config/src/index.ts"],
      "@fakt/ui": ["../../packages/ui/src/index.ts"],
      "@fakt/ai": ["../../packages/ai/src/index.ts"],
      "@fakt/pdf": ["../../packages/pdf/src/index.ts"],
      "@fakt/email": ["../../packages/email/src/index.ts"]
    },
    "types": ["vitest/globals", "@testing-library/jest-dom"]
  },
  "include": [
    "src/**/*",
    "../../packages/shared/src/**/*",
    "../../packages/design-tokens/src/**/*",
    "../../packages/core/src/**/*",
    "../../packages/legal/src/**/*",
    "../../packages/config/src/**/*",
    "../../packages/ui/src/**/*",
    "../../packages/ai/src/**/*",
    "../../packages/pdf/src/**/*",
    "../../packages/email/src/**/*"
  ],
  "exclude": ["src-tauri", "node_modules", "dist"]
}
