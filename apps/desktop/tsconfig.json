{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "paths": {
      "@fakt/shared": ["../../packages/shared/src/index.ts"],
      "@fakt/design-tokens": ["../../packages/design-tokens/src/index.ts"],
      "@fakt/core": ["../../packages/core/src/index.ts"],
      "@fakt/legal": ["../../packages/legal/src/index.ts"],
      "@fakt/config": ["../../packages/config/src/index.ts"]
    }
  },
  "include": [
    "src/**/*",
    "../../packages/shared/src/**/*",
    "../../packages/design-tokens/src/**/*",
    "../../packages/core/src/**/*",
    "../../packages/legal/src/**/*",
    "../../packages/config/src/**/*"
  ],
  "exclude": ["src-tauri", "node_modules", "dist"]
}
