{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "moduleResolution": "bundler",
    "module": "ESNext",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@fakt/shared": ["./packages/shared/src/index.ts"],
      "@fakt/design-tokens": ["./packages/design-tokens/src/index.ts"],
      "@fakt/core": ["./packages/core/src/index.ts"],
      "@fakt/legal": ["./packages/legal/src/index.ts"],
      "@fakt/db": ["./packages/db/src/index.ts"],
      "@fakt/config": ["./packages/config/src/index.ts"],
      "@fakt/ui": ["./packages/ui/src/index.ts"],
      "@fakt/pdf": ["./packages/pdf/src/index.ts"]
    }
  }
}
