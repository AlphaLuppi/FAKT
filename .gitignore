# Claude Code local config (user-specific)
# On utilise `.claude/*` + exception pour que git scanne le dir et applique
# le `!launch.json` ; avec `.claude/` tout court git skip le dir entièrement
# et ignore les exceptions à l'intérieur.
.claude/*
!.claude/launch.json
!.claude/skills/

# BMAD local artifacts (keep dir, ignore private outputs)
_bmad-output/local/
_research/private/

# SQLite runtime files
*.db-shm
*.db-wal

# Bun build
bun.lockb

# Encrypted key fallback (keychain)
*.key.enc

# Misc
*.tsbuildinfo
.eslintcache

# Temp / scratch
_tmp/
