# ============================================================================
# FAKT self-host — .env example
# ============================================================================
#
# Copier vers .env et remplir.
# .env est .gitignored — JAMAIS commit en clair.
# ============================================================================

# Domaine (DNS A doit pointer vers cette IP)
FAKT_DOMAIN=fakt.alphaluppi.fr

# Version FAKT à déployer (tag GHCR)
FAKT_VERSION=latest

# Postgres
POSTGRES_DB=fakt
POSTGRES_USER=fakt
POSTGRES_PASSWORD=changeme_strong_password_here

# JWT secret (>= 32 chars cryptographiquement aléatoires)
# Générer : openssl rand -base64 48
FAKT_JWT_SECRET=changeme_at_least_32_chars_random_secret

# Admin token one-shot pour migration data (>= 32 chars)
# Activé uniquement si présent — supprimer après migration done
# FAKT_ADMIN_TOKEN=

# Logging
LOG_LEVEL=info
