{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "FAKT Tauri dev (desktop full)",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["run", "dev"],
      "port": 1420
    },
    {
      "name": "FAKT Vite standalone (frontend only)",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["--cwd=apps/desktop", "run", "dev"],
      "port": 1420
    },
    {
      "name": "FAKT Web (mode 2 self-host bundle)",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["--cwd=apps/desktop", "run", "dev:web"],
      "port": 1420
    }
  ]
}
